# Supabase — copy to .env.local and fill in from your Supabase project settings.
# Project Settings → API

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Never expose this to the browser. Used only by scripts/optional
# server-side admin writes. The app enforces admin writes via RLS + the logged-in
# session, so this is optional unless you add service-role server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket name for uploaded images (public read). Defaults to "media".
NEXT_PUBLIC_SUPABASE_BUCKET=media
